{
  "name": "@bantayog/functions",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./lib/index.js",
  "scripts": {
    "build": "tsc",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run src/__tests__/phase1-auth.test.ts",
    "test:rules": "vitest run src/__tests__/firestore.rules.test.ts",
    "serve": "pnpm build && firebase emulators:start --only functions",
    "shell": "pnpm build && firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "bootstrap:phase1": "tsx scripts/bootstrap-phase1.ts"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "@bantayog/shared-types": "workspace:*",
    "@bantayog/shared-validators": "workspace:*",
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^7.2.5"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@types/node": "^20.12.0",
    "firebase-functions-test": "^3.3.0",
    "tsx": "^4.21.0"
  }
}
