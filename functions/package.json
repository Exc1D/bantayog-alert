{
  "name": "bantayog-alert-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for Bantayog Alert disaster reporting platform",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "18"
  },
  "keywords": [
    "firebase",
    "cloud functions",
    "disaster reporting"
  ],
  "author": "Bantayog Alert Team",
  "license": "MIT",
  "dependencies": {
    "firebase-admin": "^11.11.0",
    "firebase-functions": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3",
    "firebase-functions-test": "^3.1.0"
  },
  "private": true
}
